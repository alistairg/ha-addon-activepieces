#!/command/with-contenv bashio
# ==============================================================================
# Home Assistant Add-on: Activepieces
# Initializes Activepieces configuration
# ==============================================================================

declare data_dir="/config/activepieces"
declare secrets_file="${data_dir}/.secrets"
declare env_file="/var/run/activepieces.env"

bashio::log.info "Initializing Activepieces..."

# Create persistent data directory
mkdir -p "${data_dir}"

# Generate secrets on first run
if ! bashio::fs.file_exists "${secrets_file}"; then
    bashio::log.info "First run detected - generating secrets..."

    AP_ENCRYPTION_KEY=$(openssl rand -hex 16)
    AP_JWT_SECRET=$(openssl rand -hex 32)

    cat > "${secrets_file}" <<EOF
AP_ENCRYPTION_KEY='${AP_ENCRYPTION_KEY}'
AP_JWT_SECRET='${AP_JWT_SECRET}'
EOF

    chmod 600 "${secrets_file}"
    bashio::log.info "Secrets generated and stored."
fi

# Load secrets
# shellcheck disable=SC1090
source "${secrets_file}"

# Get ingress entry for frontend URL
if INGRESS_ENTRY=$(bashio::addon.ingress_entry 2>/dev/null); then
    bashio::log.info "Ingress entry: ${INGRESS_ENTRY}"
else
    INGRESS_ENTRY="/"
    bashio::log.warning "Could not get ingress entry, using default: ${INGRESS_ENTRY}"
fi

# Read user options
TELEMETRY_ENABLED=$(bashio::config 'telemetry_enabled' 2>/dev/null || echo "false")

# Create persistent subdirectories
mkdir -p "${data_dir}/cache"

# Symlink the cache directory so pieces persist across restarts
if [ ! -L /usr/src/app/cache ]; then
    rm -rf /usr/src/app/cache
    ln -s "${data_dir}/cache" /usr/src/app/cache
    bashio::log.info "Linked cache directory to persistent storage"
fi

# Write environment file for Activepieces service
cat > "${env_file}" <<EOF
export AP_DB_TYPE='PGLITE'
export AP_REDIS_TYPE='MEMORY'
export AP_CONFIG_PATH='${data_dir}'
export AP_ENCRYPTION_KEY='${AP_ENCRYPTION_KEY}'
export AP_JWT_SECRET='${AP_JWT_SECRET}'
export AP_ENVIRONMENT='prod'
export AP_EXECUTION_MODE='UNSANDBOXED'
export AP_TELEMETRY_ENABLED='${TELEMETRY_ENABLED}'
export AP_FRONTEND_URL='http://localhost:3000'
EOF

bashio::log.info "Activepieces initialization complete."
